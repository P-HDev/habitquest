{
  "name": "habitquest",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "api": "npm run dev -w packages/api",
    "web": "npm run dev -w packages/web",
    "test": "npm run test -w packages/api && npm run test -w packages/web",
    "test:api": "npm run test -w packages/api",
    "test:web": "npm run test -w packages/web",
    "lint": "eslint packages --ext .ts,.tsx",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.60.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
